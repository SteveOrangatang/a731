# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Required for live AI chat. Without this, the chat panel returns a stub message.
VITE_GEMINI_API_KEY=

# Optional - default is gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.0-flash

# Optional - default passcode for the Admin tab is "pilot"
VITE_ADMIN_PASSCODE=pilot
